# =============================================================================
# FPGA Brain Tumor Segmentation - .gitignore
# Optimized for Xilinx Vivado/Vitis/HLS workflows
# =============================================================================

# -----------------------------------------------------------------------------
# Xilinx Vivado Build Artifacts
# -----------------------------------------------------------------------------
*.jou
*.log
*.str
*.wdb
*.pb
*.rpx
.Xil/
.Xil_*/

# Vivado project folders (regenerated by build.tcl)
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.gen/
*.srcs/sources_1/bd/
*.xpr

# Platform/export files (regenerated)
*.xsa
*_hw_platform*/
*.pdi
*.hwh

# -----------------------------------------------------------------------------
# Xilinx Vitis / SDK Artifacts
# -----------------------------------------------------------------------------
.vitis/
.vivado/
.sdk/
workspace/
vitis_workspace/
vitis_ws/
hw_runtime/
RemoteSystemsTempFiles/
.metadata/
Debug/
Release/

# -----------------------------------------------------------------------------
# Xilinx HLS Artifacts
# -----------------------------------------------------------------------------
# HLS solution folders (fully regenerated from run_hls.tcl)
**/solution*/
*.aps
*.directive
hls.app
autopilot_*.log
vitis_hls.log
*.adb

# HLS project logs
02_hls_accelerator/otsu_hls/
02_hls_accelerator/logs/

# -----------------------------------------------------------------------------
# IP Repository Generated Files
# -----------------------------------------------------------------------------
# Generated IP archives and packaging artifacts
03_vivado_hardware/ip_repo/*.zip
03_vivado_hardware/ip_repo/ip/

# -----------------------------------------------------------------------------
# Vivado Project Outputs
# -----------------------------------------------------------------------------
03_vivado_hardware/vivado_project/
03_vivado_hardware/build/
03_vivado_hardware/.xsrc/

# Backup logs (Vivado session recovery)
vivado_*.backup.log
vivado_*.backup.jou

# -----------------------------------------------------------------------------
# Binary / Compiled Outputs
# -----------------------------------------------------------------------------
*.bit
*.bin
*.elf
*.xo
*.exe
*.o
*.a
*.so
*.dll

# Archive files (generated)
*.zip
*.tar.gz
*.tar.bz2

# -----------------------------------------------------------------------------
# Vitis Software Artifacts
# -----------------------------------------------------------------------------
04_vitis_software/build/
04_vitis_software/Debug/
04_vitis_software/Release/
04_vitis_software/*.o

# -----------------------------------------------------------------------------
# Generated Test Data (can be regenerated)
# -----------------------------------------------------------------------------
01_python_verification/bin/
01_python_verification/c_headers/
05_test_images/bin/

# Keep source images and one set of c_headers in 05_test_images/c_headers/
# These are small and needed for standalone build

# -----------------------------------------------------------------------------
# DFX Runtime (Tool-generated profiling)
# -----------------------------------------------------------------------------
dfx_runtime.txt
**/dfx_runtime.txt

# -----------------------------------------------------------------------------
# IDE / Editor Files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.cproject
.settings/
_ide/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
ENV/

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Large Binary Files (should not be in repo)
# -----------------------------------------------------------------------------
*.pptx
*.pdf
*.docx
*.mmi

# Exception: Keep documentation outputs if manually added
# !06_documentation/hardware_output/README.md
